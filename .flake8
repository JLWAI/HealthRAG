[flake8]
# Flake8 configuration for HealthRAG

# Maximum line length
max-line-length = 100

# Exclude directories
exclude =
    .git,
    __pycache__,
    venv,
    venv_mlx,
    .venv,
    build,
    dist,
    *.egg-info,
    .pytest_cache,
    .mypy_cache,
    htmlcov,
    data/

# Ignore specific error codes
ignore =
    E203,  # whitespace before ':' (conflicts with black)
    E501,  # line too long (handled by black)
    W503,  # line break before binary operator (conflicts with black)
    E402,  # module level import not at top of file (sometimes needed)
    F401,  # imported but unused (handled by mypy)

# Maximum complexity
max-complexity = 15

# Per-file ignores
per-file-ignores =
    __init__.py:F401
    tests/*:F401,F811
